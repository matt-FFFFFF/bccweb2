{
  "name": "bccweb2",
  "private": true,
  "license": "MPL-2.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "analyze": "ANALYZE=1 make build-web",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "npm run lint --workspaces --if-present && eslint tests/e2e scripts --max-warnings 0 && npm run license:check",
    "license:check": "node scripts/spdx-header.mjs",
    "license:fix": "node scripts/spdx-header.mjs --fix",
    "license:test": "node --test scripts/__tests__/spdx-header.test.mjs",
    "tfvars:test": "node --test scripts/__tests__/tfvars-to-github-env.test.mjs",
    "iac:platform-contract": "bash scripts/iac/check-shared-resource-contract.sh",
    "iac:stamp-storage-split": "bash scripts/iac/check-stamp-storage-split.sh",
    "fixtures:audit": "node scripts/audit-fixtures.mjs --json",
    "admin:test": "node --test scripts/admin/__tests__/move-manufacturers-to-public.test.mjs scripts/admin/__tests__/reconcile-orphan-igcs.test.mjs scripts/admin/__tests__/redispatch-stuck-igc-validations.test.mjs",
    "fixtures:test": "node --test scripts/__tests__/fixture-operation.test.mjs scripts/__tests__/loadtest-topology.test.mjs scripts/__tests__/seed-fixture-pilots.test.mjs scripts/__tests__/seed-fixtures.integration.test.mjs scripts/__tests__/seed-fixtures.adversarial.test.mjs scripts/__tests__/seed-fixtures.transaction.test.mjs",
    "loadtest:test": "node --test scripts/__tests__/dev-credentials.test.mjs scripts/__tests__/loadtest-*.test.mjs tests/load/*.test.mjs",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "e2e": "playwright test --config tests/e2e/playwright.config.ts"
  },
  "engines": {
    "node": "^24.0.0",
    "npm": "^11.0.0"
  },
  "devDependencies": {
    "@azure/storage-blob": "12.33.0",
    "@azure/storage-queue": "12.31.0",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "10.6.0",
    "eslint-plugin-playwright": "2.10.4",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "re2": "1.25.0",
    "rollup-plugin-visualizer": "7.0.1",
    "typescript-eslint": "8.62.1",
    "typescript-language-server": "5.3.0",
    "vitest": "4.1.9",
    "zod": "4.4.3"
  },
  "overrides": {
    "@babel/core": "^7.29.6"
  }
}
