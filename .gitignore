node_modules/
dist/
build/
.turbo/
*.tsbuildinfo
.env
.env.local
.env.*.local
.DS_Store
*.log
local.settings.json

# Azurite local storage emulator runtime state
.azurite/*
!.azurite/.gitkeep

# Migration database backups
*.bacpac

# Migration state (id-map, reconciliation reports) — operator-managed retention
.migration-state/

# Terraform
.terraform
*.tfstate
*.tfstate.backup
*.tfvars
*.tfvars.json
*tfplan*
# Bootstrap tfvars is non-secret canonical bootstrap topology.
!iac/bootstrap/terraform.tfvars
# The committed environment bases are non-secret and tracked.
!iac/env/shared.tfvars
!iac/env/staging.tfvars
!iac/env/prod.tfvars
# Bootstrap generates this non-secret file; commit it after bootstrap apply.
!iac/env/shared.generated.tfvars
!iac/env/*.tfvars.example
# Secret local overlays remain ignored even though tracked tfvars are negated above.
iac/env/*.local.tfvars

# Playwright
playwright-report/
test-results/
tests/e2e/playwright-report/
tests/e2e/test-results/

# Terraform plan artifacts
iac/plan.binary

# OpenCode session state
.opencode/
.omo/

# Load-testing fixtures and dev credentials (T1)
.dev-credentials
.fixture-manifest.json
.fixture-cleanup-state.json
.fixture-operation.lock
.loadtest-round-state.json
tests/load/.prepared-round.json

# Load-test runtime logs (k6 stdout per `make loadtest-register` / `loadtest-sign`)
logs/
.worktrees/

# Platwrigt MCP
.playwright-mcp/
