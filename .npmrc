# Honour the Node/npm floor declared in package.json "engines". A contributor on
# the wrong Node major can't silently resolve a different dependency tree.
engine-strict=true

# New installs pin exact versions (no ^/~ ranges), matching the repo's exact-pin
# policy (see commit "pin dependency versions to exact"). Keeps the single root
# lockfile deterministic; security bumps still flow via Dependabot.
save-exact=true
