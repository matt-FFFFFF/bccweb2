# PureTrack integration-test credentials (LOCAL ONLY — never commit the real .env)
#
# Copy this file to `apps/api/.env` and fill in real values.
# `.env` is gitignored; this `.env.example` is the committed template.
# Loaded by the integration test via Node 24's built-in process.loadEnvFile().
# These hit the REAL BCC PureTrack account. The integration suite is opt-in
# (VITEST_INTEGRATION=1) and self-skips when these are absent.

PURETRACK_API_KEY=
PURETRACK_EMAIL=
PURETRACK_PASSWORD=
# Comma-separated REAL PureTrack numeric pilot IDs to import, e.g. 12345,67890
PURETRACK_TEST_PILOT_IDS=
