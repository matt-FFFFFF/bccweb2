# ── Stage 1: Build ────────────────────────────────────────────────────────────
FROM node:24-alpine AS build
WORKDIR /build

# Copy manifests first for better layer caching
COPY package.json package-lock.json tsconfig.base.json ./
COPY packages/types/package.json ./packages/types/
COPY packages/schemas/package.json ./packages/schemas/
COPY packages/scoring/package.json ./packages/scoring/
COPY apps/api/package.json ./apps/api/

RUN npm ci

COPY packages/types ./packages/types
COPY packages/schemas ./packages/schemas
COPY packages/scoring ./packages/scoring
COPY apps/api ./apps/api

# Bootstrap build — workspace symlinks cannot be followed by tsc under overlayfs.
# Build each @bccweb package first, then materialise its symlink into a real
# directory (with dist/) before the next package tries to import from it.
# Dependency order: types → schemas → scoring → api.

# 1. Build types (no @bccweb imports, no project references)
RUN node_modules/.bin/tsc --project packages/types/tsconfig.json
# 2. Replace the types symlink with the real built directory (includes dist/ and .tsbuildinfo)
RUN rm -rf node_modules/@bccweb/types && cp -r packages/types node_modules/@bccweb/types
# 3. schemas imports @bccweb/types — now a real dir with dist/
RUN node_modules/.bin/tsc --project packages/schemas/tsconfig.json
# 4. Replace the schemas symlink
RUN rm -rf node_modules/@bccweb/schemas && cp -r packages/schemas node_modules/@bccweb/schemas
# 5. scoring imports @bccweb/types — now a real dir with dist/
RUN node_modules/.bin/tsc --project packages/scoring/tsconfig.json
# 6. Replace the scoring symlink
RUN rm -rf node_modules/@bccweb/scoring && cp -r packages/scoring node_modules/@bccweb/scoring
# 7. Compile the API — all @bccweb/* are real dirs with .d.ts files
RUN node_modules/.bin/tsc --project apps/api/tsconfig.json

# ── Stage 2: Runtime (official Azure Functions host) ──────────────────────────
FROM --platform=linux/amd64 mcr.microsoft.com/azure-functions/node:4-node24

ENV AzureWebJobsScriptRoot=/home/site/wwwroot \
    AzureFunctionsJobHost__Logging__Console__IsEnabled=true

WORKDIR /home/site/wwwroot

COPY --from=build /build/apps/api/host.json    ./
COPY --from=build /build/apps/api/package.json ./
COPY --from=build /build/apps/api/dist         ./dist
COPY --from=build /build/node_modules          ./node_modules
