{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "composite": false
  },
  "references": [
    { "path": "../../packages/types" }
  ],
  "include": ["src"],
  "exclude": ["src/**/__tests__/**", "src/**/*.test.tsx", "src/**/*.test.ts"]
}
