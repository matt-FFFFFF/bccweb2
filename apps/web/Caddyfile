:80 {
    root * /srv
    encode gzip

    # Proxy API calls to the Azure Functions container.
    # Browser hits /api/* on the same origin → Caddy forwards internally.
    handle /api/* {
        reverse_proxy api:80
    }

    # Proxy blob reads to Azurite, rewriting /blob/<path> →
    # /devstoreaccount1/data/<path> (mirrors the Vite dev-server proxy).
    handle_path /blob/* {
        rewrite * /devstoreaccount1/data{path}
        reverse_proxy azurite:10000
    }

    # SPA fallback — serve index.html for all unmatched routes.
    handle {
        try_files {path} /index.html
        file_server
    }
}
