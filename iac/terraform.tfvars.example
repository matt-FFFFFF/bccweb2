# Copy to terraform.tfvars and fill in real values before applying.
# Never commit terraform.tfvars — it contains secrets.
#
# Bootstrap order (first deploy):
#   1. terraform apply
#   2. scripts/iac/seed-secrets.sh   <- places jwt-secret into Key Vault
#   3. Deploy the Function App package
#
# See iac/README.md for full details.

# CORS: explicit SPA origins only; browser reads must be limited to prod/staging/localhost.
allowed_origins = [
  "https://your-prod-swa.azurestaticapps.net",
  "https://your-staging-swa.azurestaticapps.net",
  "http://localhost:5173",
]

# ACS Email
acs_email_domain   = "mail.yourdomain.com"
acs_sender_address = "noreply@mail.yourdomain.com"

# Secrets (sensitive — prefer TF_VAR_* env vars in CI rather than storing here)
round_brief_emails = "briefings@yourdomain.com"
puretrack_api_key  = "change-me"
puretrack_email    = "puretrack@yourdomain.com"
puretrack_password = "change-me"

# Observability / alert routing (T47).
# ops_email is REQUIRED — deploys fail closed if blank.
# slack_webhook_url is optional; leave empty to skip the Slack receiver.
ops_email         = "oncall@yourdomain.com"
slack_webhook_url = ""

# DNS / production hostname (T51).
# production_hostname is the public host the SPA serves traffic on after cutover.
# dns_zone_name controls who owns the CNAME:
#   ""              → operator creates the CNAME manually at their registrar.
#                     The SWA default hostname is published via the
#                     `production_hostname_target` terraform output.
#   "example.com"   → Terraform creates an azurerm_dns_cname_record in the
#                     matching Azure DNS zone. Set dns_zone_resource_group_name
#                     if the zone lives in a different RG to the rest of the
#                     stack (defaults to the bccweb resource group).
# See docs/runbooks/dns-cutover.md for the TTL strategy (300s 24h before, 3600s
# 24h after stable) and the manual operator runbook.
production_hostname          = ""
dns_zone_name                = ""
dns_zone_resource_group_name = ""

# jwt_secret is NO LONGER a Terraform variable.
# The Function App reads JWT_SECRET at runtime from Key Vault via its
# system-assigned managed identity (@Microsoft.KeyVault reference).
# After the first `terraform apply`, seed the secret out-of-band:
#   scripts/iac/seed-secrets.sh
