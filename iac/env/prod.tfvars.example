# HISTORICAL FULL-SCHEMA REFERENCE. This file documents every environment-root
# variable, secret and non-secret alike. The non-secret subset below is now
# the committed, tracked `iac/env/prod.tfvars` — do not `cp` this file over
# it; edit `prod.tfvars` directly if a committed base value needs to change.
# Secrets and bootstrap-generated values (`stamp_rg_name`, the `tfstate_*`
# values, `ops_email`, `puretrack_*`, `terraform_principal_type` for local
# human applies) live in the gitignored local overlay; copy that overlay
# from `iac/env/prod.local.tfvars.example` instead:
#   cp iac/env/prod.local.tfvars.example iac/env/prod.local.tfvars
# Apply with the committed base first, then the local overlay (overlay wins):
#   terraform -chdir=iac/environment init -backend-config=../env/prod.backend.hcl && terraform -chdir=iac/environment apply -var-file=../env/prod.tfvars -var-file=../env/prod.local.tfvars
# DO NOT COMMIT REAL SECRETS. In CI, secrets and generated values are mapped
# explicitly into TF_VAR_* job-environment entries by terraform-run.yml.

stamp_name = "prod"
location   = "uksouth"

# Local overlay values (see iac/env/prod.local.tfvars.example). CI maps
# these from GitHub environment secrets/variables via terraform-run.yml.
tfstate_resource_group_name = "rg-bccweb-tfstate" # REQUIRED: bootstrap state RG; CI maps TF_VAR_tfstate_resource_group_name
tfstate_storage_account_name = "stbccweb13afe" # REQUIRED: canonical bootstrap state account; CI maps TF_VAR_tfstate_storage_account_name
stamp_rg_name = "stamp-prod"

# CORS: replace with the real production hostname before apply.
allowed_origins = ["https://<your-prod-hostname>"]

ops_email = "<REQUIRED: operator must replace before apply>" # REQUIRED

puretrack_api_key  = "<REQUIRED: see TF_VAR_puretrack_api_key>"  # REQUIRED
puretrack_email    = "<REQUIRED: see TF_VAR_puretrack_email>"    # REQUIRED
puretrack_password = "<REQUIRED: see TF_VAR_puretrack_password>" # REQUIRED

jwt_secret_version = "1"
acs_secret_version = "1"
blob_schema_mode   = "observe"

# Principal type for the identity running Terraform. Default is ServicePrincipal
# because CI (GitHub Actions → Terraform UMI via OIDC) is the primary path.
# Override to "User" when applying locally as yourself (`az login` context).
terraform_principal_type = "ServicePrincipal"

# Optional alert receiver.
slack_webhook_url = ""
