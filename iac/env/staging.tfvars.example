# COMMITTED TEMPLATE. Copy to staging.tfvars (gitignored) and fill in:
#   cp iac/env/staging.tfvars.example iac/env/staging.tfvars
# Use with:
#   terraform -chdir=iac/environment init -backend-config=../env/staging.backend.hcl && terraform -chdir=iac/environment apply -var-file=../env/staging.tfvars
# DO NOT COMMIT REAL SECRETS. Set via env vars: TF_VAR_puretrack_api_key=... etc., or pipeline secrets.
# CI does not use this file directly — deploy workflows generate staging.tfvars at
# runtime from GitHub env-scoped vars + TF_VAR_* secrets (see .github/workflows).

stamp_name = "staging"
location   = "uksouth"

# Local applies only. CI sources these values from the TF_VAR_* GitHub environment vars.
tfstate_resource_group_name = "rg-bccweb-tfstate" # REQUIRED: bootstrap state RG; CI supplies TF_VAR_tfstate_resource_group_name
tfstate_storage_account_name = "stbccweb13afe" # REQUIRED: canonical bootstrap state account; CI supplies TF_VAR_tfstate_storage_account_name
stamp_rg_name = "stamp-staging"

# CORS: staging SWA default hostname; leave empty until known.
allowed_origins = []

ops_email = "<REQUIRED: operator must replace before apply>" # REQUIRED

# This address must be on the configured ACS sending domain.
acs_sender_address = "<REQUIRED: operator must replace before apply>" # REQUIRED

puretrack_api_key  = "<REQUIRED: see TF_VAR_puretrack_api_key>"  # REQUIRED
puretrack_email    = "<REQUIRED: see TF_VAR_puretrack_email>"    # REQUIRED
puretrack_password = "<REQUIRED: see TF_VAR_puretrack_password>" # REQUIRED

jwt_secret_version = "1"
acs_secret_version = "1"
blob_schema_mode   = "observe"

# Principal type for the identity running Terraform. Default is ServicePrincipal
# because CI (GitHub Actions → per-env Terraform UMI via OIDC) is the primary
# path. Override to "User" when applying locally as yourself (`az login` context).
terraform_principal_type = "ServicePrincipal"

# Optional alert receiver.
slack_webhook_url = ""
