# COMMITTED TEMPLATE. Copy to dev.tfvars (gitignored) and fill in:
#   cp iac/env/dev.tfvars.example iac/env/dev.tfvars
# Use with:
#   terraform -chdir=iac/service init -backend-config=../env/dev.backend.hcl && terraform -chdir=iac/service apply -var-file=../env/dev.tfvars
# DO NOT COMMIT REAL SECRETS. Set via env vars: TF_VAR_puretrack_api_key=... etc., or pipeline secrets.
# CI does not use this file directly — deploy workflows generate dev.tfvars at
# runtime from GitHub env-scoped vars + TF_VAR_* secrets (see .github/workflows).

stamp_name = "dev"
location   = "uksouth"

# Name of the tfstate storage account (bootstrap output storage_account_name) —
# the service stack reads the common stack's remote state from it.
tfstate_sa_name = "<REQUIRED: bootstrap output storage_account_name>"

# CORS: dev SWA default hostname; leave empty until known.
allowed_origins = []

ops_email = "<REQUIRED: operator must replace before apply>" # REQUIRED

# The sending domain itself lives in the common stack (iac/env/common-dev.tfvars);
# this address must be on that domain.
acs_sender_address = "<REQUIRED: operator must replace before apply>" # REQUIRED

round_brief_emails = "<REQUIRED: see TF_VAR_round_brief_emails>" # REQUIRED
puretrack_api_key  = "<REQUIRED: see TF_VAR_puretrack_api_key>" # REQUIRED
puretrack_email    = "<REQUIRED: see TF_VAR_puretrack_email>" # REQUIRED
puretrack_password = "<REQUIRED: see TF_VAR_puretrack_password>" # REQUIRED

jwt_secret_version = "1"
acs_secret_version = "1"

# Principal type for the identity running Terraform. Default is ServicePrincipal
# because CI (GitHub Actions → per-env Terraform UMI via OIDC) is the primary
# path. Override to "User" when applying locally as yourself (`az login` context).
terraform_principal_type = "ServicePrincipal"

# Leave empty until DNS/cutover is configured.
production_hostname          = ""
dns_zone_name                = ""
dns_zone_resource_group_name = ""

# Optional alert receiver.
slack_webhook_url = ""
